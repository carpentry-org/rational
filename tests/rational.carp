(load "rational.carp")
(load "Test.carp")

(use-all Rational Test)

(defn main []
  (with-test test
    (assert-equal test
      &(new 1 4)
      &(from-float 0.25f)
      "can convert correctly from float")
    (assert-equal test
      0.25f
      (to-float &(new 1 4))
      "can convert correctly to float")
    (assert-equal test
      &(new 1 4)
      &(from-double 0.25)
      "can convert correctly from double")
    (assert-equal test
      0.25
      (to-double &(new 1 4))
      "can convert correctly to double")
    (assert-equal test
      &(new 12 1)
      &(from-int 12)
      "can convert correctly from int")
    (assert-equal test 1 (to-int &(new 1 1)) "can convert correctly to int")

    (assert-equal test &(new 1 2) &(new 3 6) "new reduces to lowest terms")
    (assert-equal test
      &(new -1 2)
      &(new 1 -2)
      "new normalizes negative denominator")
    (assert-equal test &(new 1 2) &(new -1 -2) "new normalizes double negative")

    (assert-equal test
      &(new 11 18)
      &(add &(new 1 9) &(new 3 6))
      "can add correctly")
    (assert-equal test
      &(new 5 3)
      &(sub &(new 6 3) &(new 2 6))
      "can subtract correctly")
    (assert-equal test
      &(new 3 16)
      &(mul &(new 1 8) &(new 3 2))
      "can multiply correctly")
    (assert-equal test
      &(new 3 4)
      &(div &(new 3 1) &(new 8 2))
      "can divide correctly")
    (assert-equal test
      &(new 2 1)
      &(div &(new 3 1) &(new 3 2))
      "div with non-unit denominator")
    (assert-equal test
      &(new 5 6)
      &(div &(new 1 3) &(new 2 5))
      "div fractions by fractions")
    (assert-equal test
      &(new 3 20)
      &(modulo &(new 12 5) &(new 3 4))
      "can modulo correctly")

    (assert-true test (< &(new 1 3) &(new 1 2)) "< with same sign")
    (assert-false test (< &(new 1 2) &(new 1 3)) "not < when greater")
    (assert-false test (< &(new 1 2) &(new 1 2)) "not < when equal")
    (assert-true test (> &(new 1 2) &(new 1 3)) "> works")
    (assert-true test (< &(new -1 2) &(new 1 2)) "< with negative")

    (assert-equal test &(new -3 4) &(neg (new 3 4)) "neg positive")
    (assert-equal test &(new 3 4) &(neg (new -3 4)) "neg negative")
    (assert-equal test &(new 3 4) &(abs (new -3 4)) "abs negative")
    (assert-equal test &(new 3 4) &(abs (new 3 4)) "abs positive")

    (assert-equal test &(new 2 1) &(floor (new 6 3)) "floor of an exact integer")
    (assert-equal test
      &(new 0 1)
      &(floor (new 1 3))
      "floor of a positive fraction")
    (assert-equal test
      &(new 3 1)
      &(floor (new 7 2))
      "floor rounds positive down")
    (assert-equal test
      &(new -1 1)
      &(floor (new -1 3))
      "floor of a negative fraction")
    (assert-equal test
      &(new -4 1)
      &(floor (new -7 2))
      "floor rounds negative toward -inf")
    (assert-equal test
      &(new -2 1)
      &(floor (new -6 3))
      "floor of a negative exact integer")

    (assert-equal test &(new 2 1) &(ceil (new 6 3)) "ceil of an exact integer")
    (assert-equal test
      &(new 1 1)
      &(ceil (new 1 3))
      "ceil of a positive fraction")
    (assert-equal test &(new 4 1) &(ceil (new 7 2)) "ceil rounds positive up")
    (assert-equal test
      &(new 0 1)
      &(ceil (new -1 3))
      "ceil of a negative fraction")
    (assert-equal test
      &(new -3 1)
      &(ceil (new -7 2))
      "ceil rounds negative toward +inf")

    (assert-equal test &(new 2 1) &(round (new 6 3)) "round of an exact integer")
    (assert-equal test
      &(new 0 1)
      &(round (new 1 3))
      "round of a value below a half")
    (assert-equal test
      &(new 1 1)
      &(round (new 2 3))
      "round of a value above a half")
    (assert-equal test
      &(new 2 1)
      &(round (new 3 2))
      "round of a half goes away from zero")
    (assert-equal test &(new 3 1) &(round (new 5 2)) "round of a larger half")
    (assert-equal test
      &(new -1 1)
      &(round (new -2 3))
      "round of a negative above a half")
    (assert-equal test
      &(new -2 1)
      &(round (new -3 2))
      "round of a negative half goes away from zero")
    (assert-equal test
      &(new -3 1)
      &(round (new -5 2))
      "round of a larger negative half")
    (assert-equal test
      &(new 1500000000 1)
      &(round (new 1500000000 1))
      "round of a large exact integer does not overflow")
    (assert-equal test
      &(new -1500000000 1)
      &(round (new -1500000000 1))
      "round of a large negative exact integer does not overflow")
    (assert-equal test
      &(new 1000000001 1)
      &(round (new 2000000001 2))
      "round of a large half rounds away from zero without overflow")

    (assert-equal test "(Rational 3/2)" &(str &(new 3 2)) "can stringify")
    (assert-equal test
      "(Rational -1/2)"
      &(str &(new 1 -2))
      "stringify negative denominator normalizes")
    (assert-equal test 12 (hash &(new 12 1)) "can hash")

    (assert-equal test
      &(Maybe.Just (new 3 4))
      &(Rational.from-string "3/4")
      "from-string parses a simple fraction")
    (assert-equal test
      &(Maybe.Just (new 3 4))
      &(Rational.from-string "6/8")
      "from-string reduces to lowest terms")
    (assert-equal test
      &(Maybe.Just (new -2 7))
      &(Rational.from-string "-2/7")
      "from-string parses a negative numerator")
    (assert-equal test
      &(Maybe.Just (new -3 4))
      &(Rational.from-string "6/-8")
      "from-string normalizes a negative denominator")
    (assert-equal test
      &(Maybe.Just (new 5 1))
      &(Rational.from-string "5")
      "from-string parses a bare integer")
    (assert-equal test
      &(Maybe.Just (new -5 1))
      &(Rational.from-string "-5")
      "from-string parses a negative bare integer")
    (assert-equal test
      &(Maybe.Just (new 0 1))
      &(Rational.from-string "0/4")
      "from-string parses a zero numerator")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "")
      "from-string rejects the empty string")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "/4")
      "from-string rejects an empty numerator")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "3/")
      "from-string rejects an empty denominator")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "3/0")
      "from-string rejects a zero denominator")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "a/b")
      "from-string rejects non-numeric input")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "3/4/5")
      "from-string rejects too many components")
    (assert-equal test
      &(Maybe.Nothing)
      &(Rational.from-string "abc")
      "from-string rejects a non-numeric bare token")))
